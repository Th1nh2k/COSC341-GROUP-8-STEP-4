<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="52dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add / Edit Item"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Food Picture"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/imgFoodPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp"
            android:background="#EEEEEE"
            android:scaleType="centerCrop"
            android:src="@drawable/res_logo" />

        <Button
            android:id="@+id/btnUploadFoodImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Food Picture"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item name"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etItemDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etItemPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Price"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customization Options"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etItemOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter options separated by commas"
            android:minLines="3"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:layout_marginTop="8dp" />

        <CheckBox
            android:id="@+id/cbItemAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Available"
            android:textSize="18sp"
            android:textColor="#000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnSaveItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCancelItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>